Q2_DISTRIBUTED_LEARNER=1
Q2_ROLLOUT_BIND=0.0.0.0
Q2_ROLLOUT_PORT=38888
Q2_ROLLOUT_TOKEN=replace-me
Q2_ROLLOUT_RUNTIME_MANIFEST=/absolute/path/to/runtime-manifest.json
Q2_ROLLOUT_ATTESTATION_KEY_ENV=Q2_ROLLOUT_ATTESTATION_KEY
Q2_ROLLOUT_ATTESTATION_KEY=replace-with-the-same-attestation-secret-as-workers
Q2_ROLLOUT_QUORUM=1
Q2_ROLLOUT_ENVS_PER_WORKER=4
Q2_ROLLOUT_TIMEOUT=600
Q2_ROLLOUT_RECOVERY=1
Q2_ROLLOUT_LEARNER_ID=q2-ppo-shadow
Q2_ROLLOUT_LATTICE_DIR=/absolute/path/to/learner-lattice-state
Q2_ROLLOUT_LEASE_TTL=45
Q2_ROLLOUT_MAX_ATTEMPTS=3
Q2_EXT_OBS=1
Q2_RUST_LATTICE=1
