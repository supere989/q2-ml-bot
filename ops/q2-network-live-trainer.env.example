# Installed as ~/.config/q2-network-live-trainer.env with mode 0600.
# The shared token is deliberately blank in version control and staging.
Q2_ML_CLIENT_TELEMETRY_TOKEN=

Q2_NETWORK_SERVER=100.101.57.114:28000
Q2_NETWORK_TELEMETRY_SERVER=100.101.57.114:28049
Q2_NETWORK_CLIENT_BINARY=/home/raymond/q2-network-client-staging-20260713/runtime/quake2
Q2_NETWORK_CLIENT_ROOT=/home/raymond/q2-network-client-staging-20260713/runtime
Q2_NETWORK_CLIENT_DATA_ROOT=/home/raymond/q2-network-client-staging-20260713/client-data/live
Q2_NETWORK_HARNESS_PORT_BASE=39000
Q2_NETWORK_QPORT_BASE=49000
Q2_NETWORK_CLIENTS=4
Q2_NETWORK_CLIENT_TIMEOUT=30
Q2_NETWORK_ROUND_TIMEOUT=3
Q2_NETWORK_MAX_REJECTED_ECHOES=16
Q2_EXT_OBS=1
Q2_RUN_TAG=public_network_live_v1
Q2_CKPT_DIR=/home/raymond/q2-network-client-staging-20260713/training-data/checkpoints/public_network_live_v1
Q2_RESUME_DIR=/home/raymond/q2-ml-bot/checkpoints/movement_reset_v2
Q2_RUNS_DIR=/home/raymond/q2-ml-bot/runs
Q2_LATTICE_DIR=/home/raymond/q2-ml-bot/maps/generated
Q2_RUST_LATTICE=1
Q2_RUST_EXTENSION_PATH=/home/raymond/q2-rollout/python/q2_lattice_rs.so
Q2_POLICY_STATEFUL=1
LD_LIBRARY_PATH=/home/raymond/q2-network-client-staging-20260713/runtime/lib
PYTHONPATH=/home/raymond/q2-rollout/python

# Four normal protocol-34 clients collect 512 authoritative transitions per
# rollout at live frame pacing.  The low learning rate protects the movement
# warm start while public combat supplies the new experience distribution.
Q2_NETWORK_TRAIN_COMMAND="python3 -u -m train.ppo --n_servers 1 --n_bots_per_server 4 --n_ml_bots 4 --n_steps 128 --n_epochs 2 --batch_size 256 --chunk_len 16 --total_steps 50000000 --lr 1e-5 --clip_eps 0.2 --vf_coef 0.1 --ent_coef 0.005 --max_grad_norm 0.5 --aux_coef 0.01 --aim_anchor_coef 0 --lattice_direction_coef 0.02 --map_name q2dm1 --map_change_episodes 0 --max_ep_steps 1000 --timelimit 15 --fraglimit 20 --timescale 1 --save_every 8192 --seed 7132026 --deterministic 1 --resume"
