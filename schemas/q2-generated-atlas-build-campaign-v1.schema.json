{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:q2-ml:q2-generated-atlas-build-campaign-v1",
  "title": "Atomic declaration-bound generated Atlas build campaign v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "cohort_id",
    "declaration_sha256",
    "implementation",
    "claims_snapshot_sha256",
    "input_claims",
    "output_analysis",
    "expected_map_count",
    "pass_count",
    "published",
    "passed",
    "maps",
    "failures"
  ],
  "properties": {
    "schema": {"const": "q2-generated-atlas-build-campaign-v1"},
    "cohort_id": {"$ref": "#/$defs/map_id"},
    "declaration_sha256": {"$ref": "#/$defs/sha256"},
    "implementation": {"$ref": "#/$defs/implementation"},
    "claims_snapshot_sha256": {"$ref": "#/$defs/sha256"},
    "input_claims": {
      "allOf": [
        {"$ref": "#/$defs/membership"},
        {
          "properties": {
            "stage": {"const": "claims"},
            "expected_file_count": {"const": 224}
          }
        }
      ]
    },
    "output_analysis": {
      "allOf": [
        {"$ref": "#/$defs/membership"},
        {
          "properties": {
            "stage": {"const": "analysis"},
            "expected_file_count": {"const": 224}
          }
        }
      ]
    },
    "expected_map_count": {"const": 28},
    "pass_count": {"type": "integer", "minimum": 0, "maximum": 28},
    "published": {"type": "boolean"},
    "passed": {"type": "boolean"},
    "maps": {
      "type": "array",
      "minItems": 28,
      "maxItems": 28,
      "items": {"$ref": "#/$defs/map_row"}
    },
    "failures": {
      "type": "array",
      "items": {"type": "string", "minLength": 1}
    }
  },
  "oneOf": [
    {
      "properties": {
        "passed": {"const": true},
        "published": {"const": true},
        "pass_count": {"const": 28},
        "input_claims": {
          "properties": {
            "passed": {"const": true},
            "actual_file_count": {"const": 224}
          }
        },
        "output_analysis": {
          "properties": {
            "passed": {"const": true},
            "actual_file_count": {"const": 224}
          }
        },
        "maps": {
          "items": {"$ref": "#/$defs/success_map_row"}
        },
        "failures": {"maxItems": 0}
      }
    },
    {
      "properties": {
        "passed": {"const": false},
        "published": {"const": false},
        "failures": {"minItems": 1}
      }
    }
  ],
  "$defs": {
    "sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "git_sha": {
      "type": "string",
      "pattern": "^[0-9a-f]{40}$"
    },
    "map_id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9_.-]{0,63}$"
    },
    "nullable_sha256": {
      "oneOf": [
        {"$ref": "#/$defs/sha256"},
        {"type": "null"}
      ]
    },
    "implementation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "repository_commit",
        "repository_tree",
        "git_clean",
        "atlas_analyzer_authority_sha256",
        "atlas_analyzer_authority_file_count",
        "generator_sha256",
        "routes_sha256"
      ],
      "properties": {
        "repository_commit": {"$ref": "#/$defs/git_sha"},
        "repository_tree": {"$ref": "#/$defs/git_sha"},
        "git_clean": {"const": true},
        "atlas_analyzer_authority_sha256": {"$ref": "#/$defs/sha256"},
        "atlas_analyzer_authority_file_count": {
          "type": "integer",
          "minimum": 1
        },
        "generator_sha256": {"$ref": "#/$defs/sha256"},
        "routes_sha256": {"$ref": "#/$defs/sha256"}
      }
    },
    "membership": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "stage",
        "passed",
        "expected_map_count",
        "expected_file_count",
        "actual_file_count",
        "report_sha256"
      ],
      "properties": {
        "stage": {"enum": ["claims", "analysis"]},
        "passed": {"type": "boolean"},
        "expected_map_count": {"const": 28},
        "expected_file_count": {"type": "integer", "minimum": 0},
        "actual_file_count": {"type": "integer", "minimum": 0},
        "report_sha256": {"$ref": "#/$defs/sha256"}
      }
    },
    "file_identity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["bytes", "sha256"],
      "properties": {
        "bytes": {"type": "integer", "minimum": 0},
        "sha256": {"$ref": "#/$defs/sha256"}
      }
    },
    "stream_identity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["bytes", "sha256"],
      "properties": {
        "bytes": {"type": "integer", "minimum": 0},
        "sha256": {"$ref": "#/$defs/sha256"}
      }
    },
    "artifact_set": {
      "type": "object",
      "propertyNames": {
        "enum": [
          ".analysis.manifest.json",
          ".atlas.bin",
          ".atlas.bin.zst",
          ".atlas.manifest.json",
          ".navigation.bin.zst",
          ".visibility.bin.zst",
          ".design-signature.json",
          ".routes.json"
        ]
      },
      "additionalProperties": {"$ref": "#/$defs/file_identity"}
    },
    "success_artifact_set": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        ".analysis.manifest.json",
        ".atlas.bin",
        ".atlas.bin.zst",
        ".atlas.manifest.json",
        ".navigation.bin.zst",
        ".visibility.bin.zst",
        ".design-signature.json",
        ".routes.json"
      ],
      "properties": {
        ".analysis.manifest.json": {"$ref": "#/$defs/file_identity"},
        ".atlas.bin": {"$ref": "#/$defs/file_identity"},
        ".atlas.bin.zst": {"$ref": "#/$defs/file_identity"},
        ".atlas.manifest.json": {"$ref": "#/$defs/file_identity"},
        ".navigation.bin.zst": {"$ref": "#/$defs/file_identity"},
        ".visibility.bin.zst": {"$ref": "#/$defs/file_identity"},
        ".design-signature.json": {"$ref": "#/$defs/file_identity"},
        ".routes.json": {"$ref": "#/$defs/file_identity"}
      }
    },
    "analysis_manifest_binding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "sha256",
        "atlas_manifest_sha256",
        "status",
        "deterministic_rebuild",
        "bsp_sha256",
        "generator_claims_sha256",
        "analyzer_sha256",
        "atlas_sha256",
        "full_cold_proof_sha256"
      ],
      "properties": {
        "sha256": {"$ref": "#/$defs/sha256"},
        "atlas_manifest_sha256": {"$ref": "#/$defs/sha256"},
        "status": {"const": "passed"},
        "deterministic_rebuild": {"const": true},
        "bsp_sha256": {"$ref": "#/$defs/sha256"},
        "generator_claims_sha256": {"$ref": "#/$defs/sha256"},
        "analyzer_sha256": {"$ref": "#/$defs/sha256"},
        "atlas_sha256": {"$ref": "#/$defs/sha256"},
        "full_cold_proof_sha256": {"$ref": "#/$defs/sha256"}
      }
    },
    "build_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schema", "maps"],
      "properties": {
        "schema": {"const": "q2-atlas-generated-build-v1"},
        "maps": {
          "type": "array",
          "minItems": 1,
          "maxItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "canonical_map_id",
              "bsp_sha256",
              "atlas_sha256",
              "manifest_sha256"
            ],
            "properties": {
              "canonical_map_id": {"$ref": "#/$defs/map_id"},
              "bsp_sha256": {"$ref": "#/$defs/sha256"},
              "atlas_sha256": {"$ref": "#/$defs/sha256"},
              "manifest_sha256": {"$ref": "#/$defs/sha256"}
            }
          }
        }
      }
    },
    "map_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "ordinal",
        "map",
        "passed",
        "bsp_sha256",
        "generator_claims_sha256",
        "artifacts",
        "analysis_manifest",
        "build_summary",
        "build_summary_sha256",
        "stdout",
        "stderr",
        "error"
      ],
      "properties": {
        "ordinal": {"type": "integer", "minimum": 0, "maximum": 27},
        "map": {"$ref": "#/$defs/map_id"},
        "passed": {"type": "boolean"},
        "bsp_sha256": {"$ref": "#/$defs/nullable_sha256"},
        "generator_claims_sha256": {"$ref": "#/$defs/nullable_sha256"},
        "artifacts": {"$ref": "#/$defs/artifact_set"},
        "analysis_manifest": {
          "oneOf": [
            {"$ref": "#/$defs/analysis_manifest_binding"},
            {"type": "null"}
          ]
        },
        "build_summary": {
          "oneOf": [
            {"$ref": "#/$defs/build_summary"},
            {"type": "null"}
          ]
        },
        "build_summary_sha256": {"$ref": "#/$defs/nullable_sha256"},
        "stdout": {"$ref": "#/$defs/stream_identity"},
        "stderr": {"$ref": "#/$defs/stream_identity"},
        "error": {
          "oneOf": [
            {"type": "string", "minLength": 1},
            {"type": "null"}
          ]
        }
      }
    },
    "success_map_row": {
      "allOf": [
        {"$ref": "#/$defs/map_row"},
        {
          "properties": {
            "passed": {"const": true},
            "bsp_sha256": {"$ref": "#/$defs/sha256"},
            "generator_claims_sha256": {"$ref": "#/$defs/sha256"},
            "artifacts": {"$ref": "#/$defs/success_artifact_set"},
            "analysis_manifest": {
              "$ref": "#/$defs/analysis_manifest_binding"
            },
            "build_summary": {"$ref": "#/$defs/build_summary"},
            "build_summary_sha256": {"$ref": "#/$defs/sha256"},
            "error": {"type": "null"}
          }
        }
      ]
    }
  }
}
