{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:q2-ml:q2-multires-b8-gate-v1",
  "title": "B8 generated/stock/guide/shadow aggregate",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "tool", "inputs", "identities", "season_independence", "predicates", "failures", "passed", "cold_restart_pending", "automatic_promotion", "public_mutation_authorized", "gate_sha256"],
  "properties": {
    "schema": {"const": "q2-multires-b8-gate-v1"},
    "tool": {"const": "assemble_b8_b9_evidence"},
    "inputs": {
      "type": "object", "additionalProperties": false,
      "required": ["generated_gate", "stock_gate", "shadow_archive", "shadow_evidence"],
      "properties": {
        "generated_gate": {"$ref": "#/$defs/gateArtifact"},
        "stock_gate": {"$ref": "#/$defs/gateArtifact"},
        "shadow_archive": {"$ref": "#/$defs/manifestArtifact"},
        "shadow_evidence": {"$ref": "#/$defs/evidenceArtifact"}
      }
    },
    "identities": {
      "type": "object", "additionalProperties": false,
      "required": ["runtime_manifest_sha256", "atlas_catalog_sha256", "lineage_root_sha256", "artifacts", "atlases"],
      "properties": {
        "runtime_manifest_sha256": {"$ref": "#/$defs/sha256"},
        "atlas_catalog_sha256": {"$ref": "#/$defs/sha256"},
        "lineage_root_sha256": {"$ref": "#/$defs/sha256"},
        "artifacts": {"type": "object", "minProperties": 19, "maxProperties": 19, "additionalProperties": {"$ref": "#/$defs/artifact"}},
        "atlases": {
          "type": "object", "additionalProperties": false,
          "required": ["generated", "stock", "shadow"],
          "properties": {
            "generated": {"$ref": "#/$defs/atlasIdentity"},
            "stock": {"$ref": "#/$defs/atlasIdentity"},
            "shadow": {"$ref": "#/$defs/artifact"}
          }
        }
      }
    },
    "season_independence": {
      "type": "object", "additionalProperties": false,
      "required": ["generated", "stock"],
      "properties": {
        "generated": {"$ref": "#/$defs/seasonIdentity"},
        "stock": {"$ref": "#/$defs/seasonIdentity"}
      }
    },
    "predicates": {
      "type": "object", "additionalProperties": false,
      "required": ["G0", "G1_generated", "G1_stock", "G2_generated", "G2_stock", "G3_generated", "G3_stock", "G4_generated", "G4_stock", "G5_generated", "G5_stock", "G6_shadow"],
      "properties": {
        "G0": {"$ref": "#/$defs/g0Predicate"},
        "G1_generated": {"$ref": "#/$defs/predicate"},
        "G1_stock": {"$ref": "#/$defs/predicate"},
        "G2_generated": {"$ref": "#/$defs/predicate"},
        "G2_stock": {"$ref": "#/$defs/predicate"},
        "G3_generated": {"$ref": "#/$defs/predicate"},
        "G3_stock": {"$ref": "#/$defs/predicate"},
        "G4_generated": {"$ref": "#/$defs/predicate"},
        "G4_stock": {"$ref": "#/$defs/predicate"},
        "G5_generated": {"$ref": "#/$defs/predicate"},
        "G5_stock": {"$ref": "#/$defs/predicate"},
        "G6_shadow": {"$ref": "#/$defs/predicate"}
      }
    },
    "failures": {"type": "array", "items": {"type": "string"}},
    "passed": {"type": "boolean"},
    "cold_restart_pending": {"const": true},
    "automatic_promotion": {"const": false},
    "public_mutation_authorized": {"const": false},
    "gate_sha256": {"$ref": "#/$defs/sha256"}
  },
  "$defs": {
    "sha256": {"type": "string", "pattern": "^(?!0{64}$)[0-9a-f]{64}$"},
    "artifact": {"type": "object", "additionalProperties": false, "required": ["bytes", "sha256"], "properties": {"bytes": {"type": "integer", "minimum": 1}, "sha256": {"$ref": "#/$defs/sha256"}}},
    "gateArtifact": {"type": "object", "additionalProperties": false, "required": ["bytes", "sha256", "gate_sha256"], "properties": {"bytes": {"type": "integer", "minimum": 1}, "sha256": {"$ref": "#/$defs/sha256"}, "gate_sha256": {"$ref": "#/$defs/sha256"}}},
    "manifestArtifact": {"type": "object", "additionalProperties": false, "required": ["bytes", "sha256", "manifest_sha256"], "properties": {"bytes": {"type": "integer", "minimum": 1}, "sha256": {"$ref": "#/$defs/sha256"}, "manifest_sha256": {"$ref": "#/$defs/sha256"}}},
    "evidenceArtifact": {"type": "object", "additionalProperties": false, "required": ["bytes", "sha256", "evidence_sha256"], "properties": {"bytes": {"type": "integer", "minimum": 1}, "sha256": {"$ref": "#/$defs/sha256"}, "evidence_sha256": {"$ref": "#/$defs/sha256"}}},
    "atlasIdentity": {"type": "object", "additionalProperties": false, "required": ["semantic_sha256", "artifact"], "properties": {"semantic_sha256": {"$ref": "#/$defs/sha256"}, "artifact": {"$ref": "#/$defs/artifact"}}},
    "seasonIdentity": {
      "type": "object", "additionalProperties": false,
      "required": ["season_id", "archive_id", "archive_manifest_sha256", "archive_manifest_file_sha256", "current_season_file_sha256", "evaluation_file_sha256", "current_season_evidence_sha256", "evaluation_evidence_sha256", "causal_metrics_window_sha256", "network_metrics_window_sha256", "atlas_sha256", "atlas_artifact_sha256"],
      "properties": {
        "season_id": {"type": "string", "minLength": 1},
        "archive_id": {"type": "string", "minLength": 1},
        "archive_manifest_sha256": {"$ref": "#/$defs/sha256"},
        "archive_manifest_file_sha256": {"$ref": "#/$defs/sha256"},
        "current_season_file_sha256": {"$ref": "#/$defs/sha256"},
        "evaluation_file_sha256": {"$ref": "#/$defs/sha256"},
        "current_season_evidence_sha256": {"$ref": "#/$defs/sha256"},
        "evaluation_evidence_sha256": {"$ref": "#/$defs/sha256"},
        "causal_metrics_window_sha256": {"$ref": "#/$defs/sha256"},
        "network_metrics_window_sha256": {"$ref": "#/$defs/sha256"},
        "atlas_sha256": {"$ref": "#/$defs/sha256"},
        "atlas_artifact_sha256": {"$ref": "#/$defs/sha256"}
      }
    },
    "predicate": {"type": "object", "additionalProperties": false, "required": ["passed", "failures"], "properties": {"passed": {"type": "boolean"}, "failures": {"type": "array", "items": {"type": "string"}}}},
    "g0Predicate": {
      "type": "object", "additionalProperties": false,
      "required": ["passed", "failures", "evidence"],
      "properties": {
        "passed": {"type": "boolean"},
        "failures": {"type": "array", "items": {"type": "string"}},
        "evidence": {"type": "object", "additionalProperties": false, "required": ["schema", "assertions", "evidence", "evidence_sha256"], "properties": {
          "schema": {"const": "q2-multires-b8-g0-evidence-summary-v1"},
          "assertions": {"type": "object", "minProperties": 9, "maxProperties": 9, "additionalProperties": {"const": true}},
          "evidence": {"type": "object", "minProperties": 11, "maxProperties": 11, "additionalProperties": {"$ref": "#/$defs/sha256"}},
          "evidence_sha256": {"$ref": "#/$defs/sha256"}
        }}
      }
    }
  }
}
