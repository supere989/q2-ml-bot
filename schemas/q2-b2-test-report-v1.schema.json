{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:q2-ml:q2-b2-test-report-v1",
  "title": "Implementation-bound B2 test evidence",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "implementation", "runs", "failures", "passed"],
  "properties": {
    "schema": {"const": "q2-b2-test-report-v1"},
    "implementation": {"$ref": "q2-generated-atlas-build-campaign-v1.schema.json#/$defs/implementation"},
    "runs": {
      "type": "array",
      "minItems": 8,
      "maxItems": 8,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name",
          "command",
          "exit_code",
          "passed_count",
          "skipped_count",
          "ignored_count",
          "log"
        ],
        "properties": {
          "name": {"type": "string", "minLength": 1},
          "command": {
            "type": "array",
            "minItems": 1,
            "items": {"type": "string", "minLength": 1}
          },
          "exit_code": {"const": 0},
          "passed_count": {"type": "integer", "minimum": 1},
          "skipped_count": {"type": "integer", "minimum": 0},
          "ignored_count": {"type": "integer", "minimum": 0},
          "log": {
            "type": "object",
            "additionalProperties": false,
            "required": ["path", "bytes", "sha256"],
            "properties": {
              "path": {"type": "string", "pattern": "^/"},
              "bytes": {"type": "integer", "minimum": 0},
              "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
            }
          }
        }
      }
    },
    "failures": {"type": "array", "maxItems": 0},
    "passed": {"const": true}
  }
}
