{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:q2-ml:q2-generator-claims-v2",
  "title": "Canonical generator-v6 claims with source-bound compiled hook replay",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "map", "generator", "source_files", "spawns", "hazard_claims", "hook_claims", "route_claims", "routes"],
  "properties": {
    "schema": {"const": "q2-generator-claims-v2"},
    "map": {"type": "string", "pattern": "^[A-Za-z0-9_.-]{1,64}$"},
    "generator": {"const": "v6"},
    "source_files": {
      "type": "object",
      "additionalProperties": false,
      "required": ["map_sha256", "meta_sha256", "lattice_sha256", "hook_zones_sha256", "hook_materialization_sha256", "routes_sha256"],
      "properties": {
        "map_sha256": {"$ref": "#/$defs/sha256"},
        "meta_sha256": {"$ref": "#/$defs/sha256"},
        "lattice_sha256": {"$ref": "#/$defs/sha256"},
        "hook_zones_sha256": {"$ref": "#/$defs/sha256"},
        "hook_materialization_sha256": {"$ref": "#/$defs/sha256"},
        "routes_sha256": {"$ref": "#/$defs/sha256"}
      }
    },
    "spawns": {
      "type": "array", "minItems": 8, "maxItems": 8,
      "items": {
        "type": "object", "additionalProperties": false,
        "required": ["claim_id", "origin_milliunits"],
        "properties": {
          "claim_id": {"$ref": "#/$defs/claim_id"},
          "origin_milliunits": {"$ref": "#/$defs/vec3_i64"}
        }
      }
    },
    "hazard_claims": {
      "type": "array", "minItems": 1,
      "items": {
        "type": "object", "additionalProperties": false,
        "required": ["claim_id", "type", "bounds_milliunits"],
        "properties": {
          "claim_id": {"$ref": "#/$defs/claim_id"},
          "type": {"enum": ["lava", "hurt"]},
          "bounds_milliunits": {"$ref": "#/$defs/bounds_i64"}
        }
      }
    },
    "hook_claims": {
      "type": "array", "minItems": 6, "maxItems": 6,
      "items": {"$ref": "#/$defs/hook_v2"}
    },
    "route_claims": {
      "type": "array", "minItems": 1,
      "items": {
        "type": "object", "additionalProperties": false,
        "required": ["claim_id", "route_id", "source_milliunits", "target_milliunits"],
        "properties": {
          "claim_id": {"$ref": "#/$defs/claim_id"},
          "route_id": {"$ref": "#/$defs/claim_id"},
          "source_milliunits": {"$ref": "#/$defs/vec3_i64"},
          "target_milliunits": {"$ref": "#/$defs/vec3_i64"}
        }
      }
    },
    "routes": {
      "type": "array", "minItems": 1,
      "items": {
        "type": "object", "additionalProperties": false,
        "required": ["route_id", "archetype", "claimed_cost_q8", "segment_claim_ids"],
        "properties": {
          "route_id": {"$ref": "#/$defs/claim_id"},
          "archetype": {"enum": ["offense", "survival", "control", "balanced"]},
          "claimed_cost_q8": {"type": "integer", "minimum": 1, "maximum": 4294967294},
          "segment_claim_ids": {"type": "array", "minItems": 2, "items": {"$ref": "#/$defs/claim_id"}}
        }
      }
    }
  },
  "$defs": {
    "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "claim_id": {"type": "string", "pattern": "^[a-z0-9:_-]{1,127}$"},
    "vec3_i64": {"type": "array", "prefixItems": [{"type": "integer"}, {"type": "integer"}, {"type": "integer"}], "minItems": 3, "maxItems": 3},
    "bounds_i64": {"type": "array", "prefixItems": [{"type": "integer"}, {"type": "integer"}, {"type": "integer"}, {"type": "integer"}, {"type": "integer"}, {"type": "integer"}], "minItems": 6, "maxItems": 6},
    "hook_v2": {
      "type": "object", "additionalProperties": false,
      "required": ["claim_id", "source_milliunits", "anchor_milliunits", "landing_milliunits", "release_after_ticks", "distance_milliunits", "flags"],
      "properties": {
        "claim_id": {"type": "string", "pattern": "^hook:[0-9]{4}:candidate:[0-9]{4}$"},
        "source_milliunits": {"$ref": "#/$defs/vec3_i64"},
        "anchor_milliunits": {"$ref": "#/$defs/vec3_i64"},
        "landing_milliunits": {"$ref": "#/$defs/vec3_i64"},
        "release_after_ticks": {"type": "integer", "minimum": 1, "maximum": 49},
        "distance_milliunits": {"type": "integer", "minimum": 1},
        "flags": {"type": "integer", "minimum": 0, "maximum": 7}
      }
    }
  }
}
