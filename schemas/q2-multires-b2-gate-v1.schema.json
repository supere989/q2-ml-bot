{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:q2-ml:q2-multires-b2-gate-v1",
  "title": "Fail-closed multi-resolution Atlas Batch B2 gate",
  "$comment": "Historical 71453 field pins remain forensic only. A future activation is executable only through the assembler's exact qualified-successor and one-shot evidence checks; the schema alone grants no authority.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "batch",
    "status",
    "owner_directive",
    "normative_documents",
    "implementation",
    "b1_authority",
    "toolchain_qualification",
    "final_lifecycle",
    "generated_cohort",
    "stock_corpus",
    "representative_budgets",
    "dyn_evidence",
    "tests",
    "deployment",
    "gate"
  ],
  "properties": {
    "schema": {"const": "q2-multires-b2-gate-v1"},
    "batch": {"const": "B2"},
    "status": {"const": "green"},
    "owner_directive": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "replacement",
        "legacy_model_lineages",
        "operational_fallback",
        "legacy_runtime_or_model_used"
      ],
      "properties": {
        "replacement": {"const": "one-way"},
        "legacy_model_lineages": {"const": "retired"},
        "operational_fallback": {"const": "forbidden"},
        "legacy_runtime_or_model_used": {"const": false}
      }
    },
    "normative_documents": {
      "type": "object",
      "additionalProperties": false,
      "required": ["design", "plan"],
      "properties": {
        "design": {"$ref": "#/$defs/file"},
        "plan": {"$ref": "#/$defs/file"}
      }
    },
    "implementation": {"$ref": "#/$defs/implementation"},
    "toolchain_qualification": {"$ref": "#/$defs/toolchain_qualification"},
    "final_lifecycle": {"$ref": "#/$defs/final_lifecycle"},
    "b1_authority": {
      "type": "object",
      "additionalProperties": false,
      "required": ["gate", "oracles"],
      "properties": {
        "gate": {"$ref": "#/$defs/file"},
        "oracles": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "cm",
            "pmove",
            "hook",
            "fall",
            "hook_attestation",
            "atlas_verifier"
          ],
          "properties": {
            "cm": {"$ref": "#/$defs/file"},
            "pmove": {"$ref": "#/$defs/file"},
            "hook": {"$ref": "#/$defs/file"},
            "fall": {"$ref": "#/$defs/file"},
            "hook_attestation": {"$ref": "#/$defs/file"},
            "atlas_verifier": {"$ref": "#/$defs/file"}
          }
        }
      }
    },
    "generated_cohort": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "cohort_id",
        "declaration",
        "declaration_sha256",
        "source",
        "compiled",
        "compiled_cm_preflight",
        "materialized",
        "claims",
        "analysis"
      ],
      "properties": {
        "cohort_id": {
          "const": "b2g26_final_71453"
        },
        "declaration": {"$ref": "#/$defs/file"},
        "declaration_sha256": {"const": "5e77d080b17491eb54787571c50e26253bef12a38c3224d3d1c6cde1dca2c810"},
        "source": {"$ref": "#/$defs/source_stage"},
        "compiled": {"$ref": "#/$defs/compiled_stage"},
        "compiled_cm_preflight": {"$ref": "#/$defs/compiled_cm_preflight_stage"},
        "materialized": {"$ref": "#/$defs/materialized_stage"},
        "claims": {"$ref": "#/$defs/claims_stage"},
        "analysis": {"$ref": "#/$defs/analysis_stage"}
      }
    },
    "stock_corpus": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "provenance",
        "inventory",
        "atlas_set_sha256",
        "validation_set_sha256",
        "cold_elapsed_milliseconds_max",
        "map_count"
      ],
      "properties": {
        "provenance": {"$ref": "#/$defs/file"},
        "inventory": {"$ref": "#/$defs/file"},
        "atlas_set_sha256": {"$ref": "#/$defs/sha256"},
        "validation_set_sha256": {"$ref": "#/$defs/sha256"},
        "cold_elapsed_milliseconds_max": {
          "type": "integer",
          "minimum": 1,
          "maximum": 300000
        },
        "map_count": {"const": 8}
      }
    },
    "representative_budgets": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "representative_map",
        "atlas_sha256",
        "l0_chunks",
        "l0_decompressed_bytes",
        "atlas_decompressed_bytes",
        "atlas_resident_bytes",
        "atlas_build_peak_rss_bytes",
        "four_dyn_compressed_bytes",
        "four_dyn_resident_bytes",
        "four_client_feature_assembly_p99_ns"
      ],
      "properties": {
        "representative_map": {"$ref": "#/$defs/map_id"},
        "atlas_sha256": {"$ref": "#/$defs/sha256"},
        "l0_chunks": {"type": "integer", "minimum": 0, "maximum": 1200},
        "l0_decompressed_bytes": {"type": "integer", "minimum": 0, "maximum": 16777216},
        "atlas_decompressed_bytes": {"type": "integer", "minimum": 0, "maximum": 33554432},
        "atlas_resident_bytes": {"type": "integer", "minimum": 0, "maximum": 33554432},
        "atlas_build_peak_rss_bytes": {"type": "integer", "minimum": 0, "maximum": 536870912},
        "four_dyn_compressed_bytes": {"type": "integer", "minimum": 0, "exclusiveMaximum": 8388608},
        "four_dyn_resident_bytes": {"type": "integer", "minimum": 0, "exclusiveMaximum": 8388608},
        "four_client_feature_assembly_p99_ns": {"type": "integer", "minimum": 0, "exclusiveMaximum": 500000}
      }
    },
    "dyn_evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["report", "executable", "argv_preflight", "source_authority", "magic", "client_count", "host", "kernel_release", "machine_identity_sha256"],
      "properties": {
        "report": {"$ref": "#/$defs/file"},
        "executable": {"$ref": "#/$defs/file"},
        "argv_preflight": {
          "type": "object",
          "additionalProperties": false,
          "required": ["shape_preflight", "origin_binding"],
          "properties": {
            "shape_preflight": {"$ref": "#/$defs/file"},
            "origin_binding": {"$ref": "#/$defs/file"}
          }
        },
        "source_authority": {
          "type": "object",
          "additionalProperties": false,
          "required": ["helper_source_closure", "q2_lattice_source_closure"],
          "properties": {
            "helper_source_closure": {"$ref": "#/$defs/source_closure"},
            "q2_lattice_source_closure": {"$ref": "#/$defs/source_closure"}
          }
        },
        "magic": {"const": "Q2LAT002"},
        "client_count": {"const": 4},
        "host": {"const": "DESKTOP-RTX2080"},
        "kernel_release": {"type": "string", "pattern": "microsoft-standard-WSL2"},
        "machine_identity_sha256": {"$ref": "#/$defs/sha256"}
      }
    },
    "tests": {
      "type": "object",
      "additionalProperties": false,
      "required": ["report", "run_count", "passed_count"],
      "properties": {
        "report": {"$ref": "#/$defs/file"},
        "run_count": {"type": "integer", "minimum": 1},
        "passed_count": {"type": "integer", "minimum": 1}
      }
    },
    "deployment": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "public_or_teacher_service_changed",
        "cross_host_runtime_copy_performed",
        "trainer_or_tensorboard_started"
      ],
      "properties": {
        "public_or_teacher_service_changed": {"const": false},
        "cross_host_runtime_copy_performed": {"const": false},
        "trainer_or_tensorboard_started": {"const": false}
      }
    },
    "gate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "stock_q2dm1_q2dm8_cold_stable",
        "stock_pins_match",
        "generated_maps_passed",
        "generated_static_pass_rate_preserved",
        "toolchain_qualification_non_admissible",
        "compiled_cm_preflight_maps_passed",
        "oracle_failures_overridable",
        "atlas_budgets_passed",
        "feature_assembly_budget_passed",
        "dyn_snapshot_budget_passed",
        "failures",
        "green"
      ],
      "properties": {
        "stock_q2dm1_q2dm8_cold_stable": {"const": true},
        "stock_pins_match": {"const": true},
        "generated_maps_passed": {"const": 28},
        "generated_static_pass_rate_preserved": {"const": true},
        "toolchain_qualification_non_admissible": {"const": true},
        "compiled_cm_preflight_maps_passed": {"const": 28},
        "oracle_failures_overridable": {"const": false},
        "atlas_budgets_passed": {"const": true},
        "feature_assembly_budget_passed": {"const": true},
        "dyn_snapshot_budget_passed": {"const": true},
        "failures": {"type": "array", "maxItems": 0},
        "green": {"const": true}
      }
    }
  },
  "$defs": {
    "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "git_sha": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
    "map_id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9_.-]{0,63}$"},
    "file": {
      "type": "object",
      "additionalProperties": false,
      "required": ["bytes", "sha256"],
      "properties": {
        "bytes": {"type": "integer", "minimum": 0},
        "sha256": {"$ref": "#/$defs/sha256"}
      }
    },
    "source_input": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "sha256", "size_bytes"],
      "properties": {
        "path": {"type": "string", "minLength": 1},
        "sha256": {"$ref": "#/$defs/sha256"},
        "size_bytes": {"type": "integer", "minimum": 0}
      }
    },
    "source_closure": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "algorithm",
        "sha256",
        "embedded_sha256",
        "repo_commit",
        "commit_binding_algorithm",
        "commit_bound_sha256",
        "inputs"
      ],
      "properties": {
        "algorithm": {"const": "sha256(canonical-json([{path,sha256},...]))-v1"},
        "sha256": {"$ref": "#/$defs/sha256"},
        "embedded_sha256": {"$ref": "#/$defs/sha256"},
        "repo_commit": {"$ref": "#/$defs/git_sha"},
        "commit_binding_algorithm": {"const": "sha256(canonical-json({repo_commit,source_closure_sha256}))-v1"},
        "commit_bound_sha256": {"$ref": "#/$defs/sha256"},
        "inputs": {
          "type": "array",
          "minItems": 1,
          "items": {"$ref": "#/$defs/source_input"}
        }
      }
    },
    "implementation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "repository_commit",
        "repository_tree",
        "git_clean",
        "atlas_analyzer_authority_sha256",
        "atlas_analyzer_authority_file_count",
        "generator_sha256",
        "routes_sha256"
      ],
      "properties": {
        "repository_commit": {"$ref": "#/$defs/git_sha"},
        "repository_tree": {"$ref": "#/$defs/git_sha"},
        "git_clean": {"const": true},
        "atlas_analyzer_authority_sha256": {"$ref": "#/$defs/sha256"},
        "atlas_analyzer_authority_file_count": {"type": "integer", "minimum": 1},
        "generator_sha256": {"$ref": "#/$defs/sha256"},
        "routes_sha256": {"$ref": "#/$defs/sha256"}
      }
    },
    "toolchain_qualification": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "report", "schema", "qualification_id", "status",
        "non_admissible", "retryable", "final_cohort_authorized",
        "end_to_end_pass_count", "required_end_to_end_pass_count",
        "activation_successor_policy", "implementation_successor", "preactivation_tests"
      ],
      "properties": {
        "report": {"$ref": "#/$defs/file"},
        "schema": {"const": "q2-b2-toolchain-qualification-v1"},
        "qualification_id": {"type": "string", "minLength": 1},
        "status": {"const": "green"},
        "non_admissible": {"const": true},
        "retryable": {"const": true},
        "final_cohort_authorized": {"const": false},
        "end_to_end_pass_count": {"type": "integer", "minimum": 20, "maximum": 28},
        "required_end_to_end_pass_count": {"const": 20},
        "activation_successor_policy": {"$ref": "#/$defs/activation_successor_policy"},
        "implementation_successor": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "qualified_repository_commit", "qualified_repository_tree",
            "final_repository_commit", "final_repository_tree",
            "stable_authority_equal", "changed_paths"
          ],
          "properties": {
            "qualified_repository_commit": {"$ref": "#/$defs/git_sha"},
            "qualified_repository_tree": {"$ref": "#/$defs/git_sha"},
            "final_repository_commit": {"$ref": "#/$defs/git_sha"},
            "final_repository_tree": {"$ref": "#/$defs/git_sha"},
            "stable_authority_equal": {"const": true},
            "changed_paths": {
              "const": [
                "AGENTS.md",
                "docs/multires/B2-C-GENERATOR-CLAIM-CONTRACT.md",
                "docs/multires/B2-GATE-ASSEMBLY.md",
                "docs/multires/B2-GENERATED-COHORT-71454-DECLARATION.json",
                "docs/multires/B2-GENERATED-COHORT-DECLARATION.json",
                "schemas/q2-multires-b2-gate-v1.schema.json",
                "tests/test_b2_gate.py",
                "tests/test_b2_operational_docs.py",
                "tests/test_generator_claim_campaign.py",
                "tests/test_generator_cohort.py",
                "tests/test_retired_cohort_registry.py",
                "tools/assemble_b2_gate.py"
              ]
            }
          }
        },
        "preactivation_tests": {"$ref": "#/properties/tests"}
      }
    },
    "activation_successor_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schema", "cohort_id", "immutable_declaration_path", "allowed_changed_paths"],
      "properties": {
        "schema": {"const": "q2-b2-final-activation-successor-policy-v1"},
        "cohort_id": {"const": "b2g26_final_71454"},
        "immutable_declaration_path": {"const": "docs/multires/B2-GENERATED-COHORT-71454-DECLARATION.json"},
        "allowed_changed_paths": {
          "const": [
            "AGENTS.md",
            "docs/multires/B2-C-GENERATOR-CLAIM-CONTRACT.md",
            "docs/multires/B2-GATE-ASSEMBLY.md",
            "docs/multires/B2-GENERATED-COHORT-71454-DECLARATION.json",
            "docs/multires/B2-GENERATED-COHORT-DECLARATION.json",
            "schemas/q2-multires-b2-gate-v1.schema.json",
            "tests/test_b2_gate.py",
            "tests/test_b2_operational_docs.py",
            "tests/test_generator_claim_campaign.py",
            "tests/test_generator_cohort.py",
            "tests/test_retired_cohort_registry.py",
            "tools/assemble_b2_gate.py"
          ]
        }
      }
    },
    "final_lifecycle": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "evidence",
        "schema",
        "status",
        "cohort_id",
        "declaration",
        "plan_sha256",
        "implementation",
        "execution_binding",
        "source_authorization_marker",
        "completed_stages",
        "stage_executions",
        "assembly_command_sha256"
      ],
      "properties": {
        "evidence": {"$ref": "#/$defs/file"},
        "schema": {"const": "q2-b2-final-lifecycle-preassembly-v1"},
        "status": {"const": "ready-for-assembly"},
        "cohort_id": {"$ref": "#/$defs/map_id"},
        "declaration": {"$ref": "#/$defs/final_lifecycle_declaration"},
        "plan_sha256": {"$ref": "#/$defs/sha256"},
        "implementation": {"$ref": "#/$defs/implementation"},
        "execution_binding": {"$ref": "#/$defs/final_execution_binding"},
        "source_authorization_marker": {"$ref": "#/$defs/path_file"},
        "completed_stages": {
          "const": [
            "dyn-shape-preflight",
            "source",
            "compile",
            "compiled-membership",
            "compiled-static",
            "compiled-cm-preflight",
            "materialization",
            "materialized-membership",
            "claims-prepare",
            "atlas-build",
            "generated-promotion",
            "stock-campaign",
            "dyn-origin-binding",
            "dyn-execute",
            "test-suite"
          ]
        },
        "stage_executions": {
          "type": "array",
          "minItems": 15,
          "maxItems": 15,
          "items": {"$ref": "#/$defs/final_lifecycle_stage_execution"}
        },
        "assembly_command_sha256": {"$ref": "#/$defs/sha256"}
      }
    },
    "final_lifecycle_declaration": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "sha256"],
      "properties": {
        "path": {"type": "string", "minLength": 1},
        "sha256": {"$ref": "#/$defs/sha256"}
      }
    },
    "path_file": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "bytes", "sha256"],
      "properties": {
        "path": {"type": "string", "minLength": 1},
        "bytes": {"type": "integer", "minimum": 0},
        "sha256": {"$ref": "#/$defs/sha256"}
      }
    },
    "final_execution_binding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schema", "host", "state_root"],
      "properties": {
        "schema": {"const": "q2-b2-final-execution-binding-v2"},
        "host": {
          "type": "object",
          "additionalProperties": false,
          "required": ["hostname", "kernel_release", "machine_identity", "euid"],
          "properties": {
            "hostname": {"const": "DESKTOP-RTX2080"},
            "kernel_release": {
              "type": "string",
              "pattern": "microsoft-standard-WSL2"
            },
            "machine_identity": {
              "type": "object",
              "additionalProperties": false,
              "required": ["path", "sha256"],
              "properties": {
                "path": {"const": "/etc/machine-id"},
                "sha256": {"$ref": "#/$defs/sha256"}
              }
            },
            "euid": {"type": "integer", "minimum": 0}
          }
        },
        "state_root": {
          "type": "object",
          "additionalProperties": false,
          "required": ["path", "owner_uid", "mode", "device", "inode"],
          "properties": {
            "path": {"type": "string", "minLength": 1},
            "owner_uid": {"type": "integer", "minimum": 0},
            "mode": {"const": "0700"},
            "device": {"type": "integer", "minimum": 0},
            "inode": {"type": "integer", "minimum": 1}
          }
        }
      }
    },
    "final_lifecycle_stage_execution": {
      "type": "object",
      "additionalProperties": false,
      "required": ["stage", "command_sha256", "returncode", "stdout", "stderr"],
      "properties": {
        "stage": {
          "enum": [
            "dyn-shape-preflight",
            "source",
            "compile",
            "compiled-membership",
            "compiled-static",
            "compiled-cm-preflight",
            "materialization",
            "materialized-membership",
            "claims-prepare",
            "atlas-build",
            "generated-promotion",
            "stock-campaign",
            "dyn-origin-binding",
            "dyn-execute",
            "test-suite"
          ]
        },
        "command_sha256": {"$ref": "#/$defs/sha256"},
        "returncode": {"const": 0},
        "stdout": {"$ref": "#/$defs/file"},
        "stderr": {"$ref": "#/$defs/file"}
      }
    },
    "source_stage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["report", "primary_membership_sha256", "cold_membership_sha256", "map_count"],
      "properties": {
        "report": {"$ref": "#/$defs/file"},
        "primary_membership_sha256": {"$ref": "#/$defs/sha256"},
        "cold_membership_sha256": {"$ref": "#/$defs/sha256"},
        "map_count": {"const": 28}
      }
    },
    "compiled_stage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["membership", "static", "map_count"],
      "properties": {
        "membership": {"$ref": "#/$defs/file"},
        "static": {"$ref": "#/$defs/file"},
        "map_count": {"const": 28}
      }
    },
    "compiled_cm_preflight_stage": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "report", "schema", "stage", "admission_status",
        "compiled_membership_sha256", "implementation_source_closure_sha256",
        "map_count", "pass_count"
      ],
      "properties": {
        "report": {"$ref": "#/$defs/file"},
        "schema": {"const": "q2-b2-compiled-cm-preflight-v1"},
        "stage": {"const": "post-q2tool-compiled-cm-preflight"},
        "admission_status": {"const": "non-admissible-preflight-only"},
        "compiled_membership_sha256": {"$ref": "#/$defs/sha256"},
        "implementation_source_closure_sha256": {"$ref": "#/$defs/sha256"},
        "map_count": {"const": 28},
        "pass_count": {"const": 28}
      }
    },
    "materialized_stage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["membership", "attestation_set_sha256", "map_count"],
      "properties": {
        "membership": {"$ref": "#/$defs/file"},
        "attestation_set_sha256": {"$ref": "#/$defs/sha256"},
        "map_count": {"const": 28}
      }
    },
    "claims_stage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["prepare_report", "claims_membership_sha256", "claims_set_sha256", "map_count"],
      "properties": {
        "prepare_report": {"$ref": "#/$defs/file"},
        "claims_membership_sha256": {"$ref": "#/$defs/sha256"},
        "claims_set_sha256": {"$ref": "#/$defs/sha256"},
        "map_count": {"const": 28}
      }
    },
    "analysis_stage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["build_report", "validation_report", "analysis_membership_sha256", "atlas_set_sha256", "map_count"],
      "properties": {
        "build_report": {"$ref": "#/$defs/file"},
        "validation_report": {"$ref": "#/$defs/file"},
        "analysis_membership_sha256": {"$ref": "#/$defs/sha256"},
        "atlas_set_sha256": {"$ref": "#/$defs/sha256"},
        "map_count": {"const": 28}
      }
    }
  }
}
